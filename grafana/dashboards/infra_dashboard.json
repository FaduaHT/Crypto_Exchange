{
  "id": null,
  "uid": "infra-crypto",
  "title": "Infraestructura - Crypto Pipeline",
  "tags": ["infra", "docker"],
  "timezone": "browser",
  "schemaVersion": 36,
  "refresh": "5s",
  "time": {"from": "now-15m", "to": "now"},
  "panels": [
    {
      "id": 1,
      "title": "CPU Usage por contenedor",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "expr": "rate(container_cpu_usage_seconds_total{name!=\"\"}[1m])",
          "legendFormat": "{{name}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0}
    },
    {
      "id": 2,
      "title": "Memoria Usada por contenedor (MB)",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "expr": "container_memory_usage_bytes{name!=\"\"} / 1024 / 1024",
          "legendFormat": "{{name}}"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0}
    },
    {
      "id": 3,
      "title": "CPU del Host (%)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "expr": "100 - (avg(irate(node_cpu_seconds_total{mode=\"idle\"}[5m])) * 100)",
          "legendFormat": "CPU %"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 8}
    },
    {
      "id": 4,
      "title": "RAM del Host (%)",
      "type": "stat",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "expr": "(1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes)) * 100",
          "legendFormat": "RAM %"
        }
      ],
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 8}
    },
    {
      "id": 5,
      "title": "Tráfico de Red RX por contenedor",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "expr": "rate(container_network_receive_bytes_total{name!=\"\"}[1m])",
          "legendFormat": "{{name}} RX"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12}
    },
    {
      "id": 6,
      "title": "Tráfico de Red TX por contenedor",
      "type": "timeseries",
      "datasource": {"type": "prometheus", "uid": "PBFA97CFB590B2093"},
      "targets": [
        {
          "expr": "rate(container_network_transmit_bytes_total{name!=\"\"}[1m])",
          "legendFormat": "{{name}} TX"
        }
      ],
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12}
    }
  ]
}
